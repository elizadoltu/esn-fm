    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
